# ─────────────────────────────────────────────────────────────
# form. intel — environment variables
# Copy to .env.local for local dev. In production, set these in Vercel.
# NEVER commit real values. .env* is gitignored.
# ─────────────────────────────────────────────────────────────

# Session signing secret. Generate with:  openssl rand -hex 32
AUTH_SECRET=

# Named users who can log in. JSON array of { user, pass }.
# Set this only in Vercel (encrypted). Add/remove people by editing this value.
SITE_USERS=[{"user":"donnieladd","pass":"change-me"},{"user":"founder","pass":"change-me"}]

# ── Model provider keys (add the ones you want available) ──
# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Grok (xAI)
XAI_API_KEY=
GROK_MODEL=grok-2-latest

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
